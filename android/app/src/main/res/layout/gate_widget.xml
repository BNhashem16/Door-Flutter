<?xml version="1.0" encoding="utf-8"?>
<!-- Home-screen gate control widget. The whole card is the tap target. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl">

    <LinearLayout
        android:id="@+id/gate_button"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/gate_widget_bg"
        android:padding="12dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/gate_icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_gate_closed"
            android:contentDescription="حالة البوابة" />

        <TextView
            android:id="@+id/gate_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="البوابة مغلقة"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/gate_action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="اضغط للفتح"
            android:textColor="#C8FFFFFF"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/gate_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="—"
            android:textColor="#99FFFFFF"
            android:textSize="11sp" />
    </LinearLayout>
</FrameLayout>
