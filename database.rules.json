{
  "rules": {
    "app_users": {
      ".read": "auth != null && root.child('app_users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["role"],
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('app_users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && ((auth.uid === $uid && !data.exists() && newData.child('role').val() === 'user' && newData.child('status').val() === 'pending' && newData.child('emailVerified').val() === false) || (auth.uid === $uid && data.exists() && newData.child('role').val() === data.child('role').val() && newData.child('status').val() === data.child('status').val() && newData.child('email').val() === data.child('email').val() && newData.child('createdAt').val() === data.child('createdAt').val() && (newData.child('emailVerified').isBoolean() || !newData.child('emailVerified').exists())) || root.child('app_users').child(auth.uid).child('role').val() === 'admin')",
        ".validate": "newData.hasChildren(['email', 'name', 'role', 'status', 'createdAt'])"
      }
    },
    "users": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "fcm_tokens": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "gate_logs": {
      ".read": "auth != null && root.child('app_users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('app_users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('app_users').child(auth.uid).child('role').val() === 'admin')",
        "$logId": {
          ".validate": "newData.hasChildren(['action', 'timestamp'])"
        }
      }
    },
    "guest_passes": {
      ".read": "auth != null && root.child('app_users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('app_users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('app_users').child(auth.uid).child('role').val() === 'admin')",
        "$passId": {
          ".validate": "newData.hasChildren(['token', 'createdBy', 'expiresAt', 'status'])"
        }
      }
    }
  }
}
