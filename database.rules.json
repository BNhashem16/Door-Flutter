{
  "rules": {
    "app_users": {
      ".read": "auth != null && root.child('app_users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["role"],
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('app_users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && ((auth.uid === $uid && !data.exists() && newData.child('role').val() === 'user' && (newData.child('status').val() === 'approved' || newData.child('status').val() === 'pending') && newData.child('emailVerified').val() === false) || (auth.uid === $uid && data.exists() && newData.child('role').val() === data.child('role').val() && newData.child('status').val() === data.child('status').val() && newData.child('email').val() === data.child('email').val() && newData.child('createdAt').val() === data.child('createdAt').val() && (newData.child('emailVerified').isBoolean() || !newData.child('emailVerified').exists())) || (auth.uid === $uid && !newData.exists()) || root.child('app_users').child(auth.uid).child('role').val() === 'admin')",
        ".validate": "newData.hasChildren(['email', 'name', 'role', 'status', 'createdAt'])"
      }
    },
    "users": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "fcm_tokens": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "gate_logs": {
      ".read": "auth != null && root.child('app_users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('app_users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('app_users').child(auth.uid).child('role').val() === 'admin')",
        "$logId": {
          ".validate": "newData.hasChildren(['action', 'timestamp'])"
        }
      }
    },
    "guest_passes": {
      ".read": "auth != null && root.child('app_users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('app_users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('app_users').child(auth.uid).child('role').val() === 'admin')",
        "$passId": {
          ".validate": "newData.hasChildren(['token', 'createdBy', 'expiresAt', 'status'])"
        }
      }
    },
    "support_tickets": {
      ".read": "auth != null && root.child('app_users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('app_users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('app_users').child(auth.uid).child('role').val() === 'admin')",
        "$ticketId": {
          ".validate": "newData.hasChildren(['message', 'createdAt', 'status'])"
        }
      }
    },
    "push_outbox": {
      ".read": "auth != null && root.child('app_users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('app_users').child(auth.uid).child('role').val() === 'admin'",
      "$pushId": {
        ".write": "auth != null && !data.exists() && (newData.child('type').val() === 'new_user' || newData.child('type').val() === 'code_request') && newData.child('targetUid').val() === auth.uid",
        ".validate": "newData.hasChildren(['type', 'createdAt'])"
      }
    },
    "notifications": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('app_users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('app_users').child(auth.uid).child('role').val() === 'admin')",
        "$noteId": {
          ".validate": "newData.hasChildren(['title', 'createdAt'])"
        }
      }
    },
    "ring_request": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('app_users').child(auth.uid).child('status').val() === 'approved'"
    },
    "notification_prefs": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "app_config": {
      ".read": true,
      ".write": "auth != null && root.child('app_users').child(auth.uid).child('role').val() === 'admin'",
      "latestBuild": { ".validate": "newData.isNumber()" },
      "minBuild": { ".validate": "newData.isNumber()" },
      "apkUrl": { ".validate": "newData.isString()" },
      "notes": { ".validate": "newData.isString()" },
      "gateAlerts": { ".validate": "newData.isBoolean()" }
    },
    "audit_logs": {
      ".read": "auth != null && root.child('app_users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('app_users').child(auth.uid).child('role').val() === 'admin'",
      "$entryId": {
        ".validate": "newData.hasChildren(['actorUid', 'action', 'timestamp'])"
      }
    },
    "access_codes": {
      ".read": "auth != null && root.child('app_users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".write": "auth != null && root.child('app_users').child(auth.uid).child('role').val() === 'admin'",
        ".validate": "newData.hasChildren(['code', 'expiresAt'])"
      }
    }
  }
}
