# Brevo (Sendinblue) transactional-email config for client-side OTP.
# Copy to `.env` and fill with real values. NEVER commit `.env`.
# Create/rotate keys at: Brevo -> SMTP & API -> API Keys.
BREVO_API_KEY=xkeysib-xxxxxxxx
BREVO_SENDER_EMAIL=you@verified-domain.com
BREVO_SENDER_NAME=Door
BREVO_SMTP_KEY=xsmtpsib-xxxxxxxx
